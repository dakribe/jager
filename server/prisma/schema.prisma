generator client {
  provider = "prisma-client-js"
}

generator pothos {
  provider     = "prisma-pothos-types"
  clientOutput = "@prisma/client"
  output       = "./generated.d.ts"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Post {
  id      String @id @default(cuid())
  content String
}
