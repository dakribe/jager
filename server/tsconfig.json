{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": false,
    "moduleResolution": "Node",
    "target": "es2020",
    "outDir": "dist",
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "exclude": [
    "node_modules/"
  ]
}
